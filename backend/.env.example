# --- Auth (Section 6: single user, no DB) ---
AUTH_USERNAME=username
AUTH_PASSWORD_HASH=replace_with_generated_bcrypt_hash
JWT_SECRET_KEY=replace_with_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- OCR (Section 2) ---
OCR_ENGINE=tesseract
TESSERACT_CMD=/path/to/tesseract

# --- Storage ---
STORAGE_DIR=./storage
SESSION_TTL_MINUTES=120

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:5173

# --- Vision API (optional, for scanned/handwritten PDF accuracy) ---
# Leave VISION_API_KEY blank to use free Tesseract only.
VISION_PROVIDER=openai
VISION_API_KEY=
VISION_MODEL=gpt-4o