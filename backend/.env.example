# --- Auth ---
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=replace_with_generated_bcrypt_hash
JWT_SECRET_KEY=replace_with_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- OCR ---
OCR_ENGINE=tesseract
# Local Windows dev: C:\Program Files\Tesseract-OCR\tesseract.exe
# Production (Render/Linux): /usr/bin/tesseract
TESSERACT_CMD=/usr/bin/tesseract

# --- Vision API (optional) ---
VISION_PROVIDER=openrouter
VISION_API_KEY=
VISION_MODEL=openai/gpt-4o

# --- Storage ---
# Production: must match the Render persistent disk mount path exactly
STORAGE_DIR=/app/storage
SESSION_TTL_MINUTES=120

# --- CORS ---
# Production: your real Vercel URL, not localhost
FRONTEND_ORIGIN=https://your-frontend.vercel.app